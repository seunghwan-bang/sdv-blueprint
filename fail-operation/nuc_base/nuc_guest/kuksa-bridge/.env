# Fail-Operation Guest Container Configuration
# Runtime에 수정 가능
# Guest Node IP: 192.168.0.2
# Master Node IP: 192.168.0.3

# KUKSA Databroker Configuration
MASTER_IP=192.168.0.3
KUKSA_PORT=55556
KUKSA_PROTOCOL=grpc

# Trigger Script Configuration
# Toggle mode: ON script when button pressed, OFF script when pressed again
TRIGGER_ON_SCRIPT=/app/script/trigger-on.sh
TRIGGER_OFF_SCRIPT=/app/script/trigger-off.sh

